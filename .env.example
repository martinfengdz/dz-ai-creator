# ============================================
# DZAI内容创作平台 — 环境变量示例
# ============================================
# 生产环境推荐使用 Docker Compose + secrets 目录
# 开发环境可直接修改此文件

# --- 数据库配置（两个根信任之一） ---
DATABASE_URL=postgres://dz_ai_creator:your_password@localhost:5432/dz_ai_creator?sslmode=disable
DATABASE_URL_FILE=

# --- 主密钥（两个根信任之二） ---
# 生成：openssl rand -base64 32
APP_SECRETS_MASTER_KEY=BASE64_ENCODED_32_BYTE_KEY
APP_SECRETS_MASTER_KEY_FILE=
APP_SECRETS_KEY_VERSION=1

# --- 运行时配置 ---
APP_BASE_URL=http://localhost:8888
LISTEN_ADDR=:8888
APP_VERSION=v2.1.0
FRONTEND_DIST_PATH=web/dist
ASSET_STORAGE_PATH=data/assets
STORAGE_TYPE=local

# --- 数据库迁移 ---
# bootstrap: 首次启动自动创建表
# existing: 已有表后的正常启动
STARTUP_DATABASE_MIGRATIONS=bootstrap

# --- AI 模型（默认模型及可用模型列表） ---
DEFAULT_IMAGE_MODEL=gpt-image-2
ALLOWED_IMAGE_MODELS=gpt-image-2

# --- API 代理地址 ---
OPENAI_BASE_URL=https://api.openai.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_PROMPT_MODEL=deepseek-chat

# --- 第三方服务 ---
SMS_PROVIDER=aliyun
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIPAY_SANDBOX=true

# --- 源码地址（AGPL-3.0 合规） ---
VITE_SOURCE_CODE_URL=https://github.com/martinfengdz/dz-ai-creator

# --- 业务密钥（请勿提交真实值） ---
# 通过在管理后台配置，或一次性命令导入：
#   docker exec dz-ai-creator dz-ai-creator secrets import-env --actor admin
# 支持的变量名见 docs/self-hosting.md
