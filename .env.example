# Minimal external trust roots. Prefer *_FILE in production.
DATABASE_URL=postgres://image_agent:change-me@postgres:5432/image_agent?sslmode=disable
DATABASE_URL_FILE=
APP_SECRETS_MASTER_KEY=BASE64_ENCODED_32_BYTE_KEY
APP_SECRETS_MASTER_KEY_FILE=
APP_SECRETS_KEY_VERSION=1

# Public, non-secret runtime settings.
APP_BASE_URL=http://localhost:8888
LISTEN_ADDR=:8888
APP_VERSION=local
FRONTEND_DIST_PATH=web/dist
ASSET_STORAGE_PATH=data/assets
STORAGE_TYPE=local
STARTUP_DATABASE_MIGRATIONS=bootstrap
DEFAULT_IMAGE_MODEL=gpt-image-2
ALLOWED_IMAGE_MODELS=gpt-image-2
OPENAI_BASE_URL=https://api.openai.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_PROMPT_MODEL=deepseek-chat
SMS_PROVIDER=aliyun
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIPAY_SANDBOX=true
VITE_SOURCE_CODE_URL=https://github.com/martinfengdz/dz-ai-creator

# Business credentials are intentionally absent. Import them once with:
#   go run ./cmd/secrets import-env
# Supported names are documented in docs/self-hosting.md. Do not commit values.
